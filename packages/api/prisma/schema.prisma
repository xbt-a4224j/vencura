// VenCura base schema. The chain is the source of truth; Postgres is a derived,
// cached projection (CLAUDE.md §4). Money is stored as bigint strings, never floats (§7).

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id           String   @id @default(uuid())
  email        String   @unique
  passwordHash String
  // Demo accounts (seed + admin-created) all use the shared demo password, so the one-click
  // User-view picker lists ONLY these — real/test registrations (their own passwords) never
  // appear and so can never 401 the picker.
  isDemo       Boolean  @default(false)
  createdAt    DateTime @default(now())

  wallets Wallet[]

  @@map("users")
}

model Wallet {
  id      String @id @default(uuid())
  userId  String
  address String @unique

  // AES-256-GCM envelope for the private key, written by EncryptedKeySigner (T-008).
  // The key is decrypted in memory only at sign time and is never returned by the API.
  encryptedPrivateKey String
  encryptionIv        String
  encryptionAuthTag   String

  // Next nonce to use; the per-wallet nonce lock serializes reads/increments (T-016).
  nextNonce Int      @default(0)
  createdAt DateTime @default(now())

  user           User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  transactions   Transaction[]
  signedMessages SignedMessage[]
  balances       WalletBalance[]
  policy         WalletPolicy?
  received       ReceivedTransfer[]

  @@index([userId])
  @@map("wallets")
}

// Inbound transfers (ETH + ERC-20) credited TO a wallet that VenCura did NOT initiate — e.g. a
// faucet drip, a deposit, or another wallet sending in. The chain is the source of truth: a tx is
// recorded under the SENDER's wallet, so without this a recipient's feed never shows funds received.
// IncomingWatcher backfills these from chain logs/blocks so the activity feed matches the explorer.
model ReceivedTransfer {
  id          String   @id @default(uuid())
  walletId    String
  txHash      String
  logIndex    Int      @default(0) // ERC-20 log position; -1 for a native-ETH transfer (no log)
  asset       String // 'ETH' or the token contract address
  amount      String // wei / token base units (bigint string)
  fromAddress String
  blockNumber BigInt
  createdAt   DateTime @default(now())

  wallet Wallet @relation(fields: [walletId], references: [id], onDelete: Cascade)

  @@unique([walletId, txHash, logIndex]) // idempotent indexing: re-scanning a block can't double-insert
  @@index([walletId, blockNumber])
  @@map("received_transfers")
}

// Single-row-per-name scan cursor so the incoming-transfer watcher resumes where it left off
// instead of re-scanning history every tick.
model ChainCursor {
  name      String   @id
  value     BigInt
  updatedAt DateTime @updatedAt

  @@map("chain_cursor")
}

// Off-chain activity: persisted signMessage results (the on-chain half lives in
// `transactions`). Together they back the unified on/off-chain history (T-023).
model SignedMessage {
  id        String   @id @default(uuid())
  walletId  String
  message   String
  signature String
  createdAt DateTime @default(now())

  wallet Wallet @relation(fields: [walletId], references: [id], onDelete: Cascade)

  @@index([walletId])
  @@map("signed_messages")
}

model WalletPolicy {
  walletId   String  @id
  perTxLimit String?
  dailyLimit String?
  wallet     Wallet  @relation(fields: [walletId], references: [id], onDelete: Cascade)

  @@map("wallet_policies")
}

enum TransactionStatus {
  pending
  confirmed
  failed
}

model Transaction {
  id             String            @id @default(uuid())
  walletId       String
  idempotencyKey String?           @unique
  nonce          Int?
  status         TransactionStatus @default(pending)
  asset          String // 'ETH' for native, the ERC-20 contract address, or 'CALL' for a contract write
  amount         String // base units (wei / token decimals) as a bigint string — never a float
  method         String? // for a contract write (asset='CALL'): the function called, e.g. 'approve' — so the activity log reads "approve → token" instead of "sent 0 tokens"
  toAddress      String
  fromAddress    String
  txHash         String?           @unique
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt

  wallet Wallet @relation(fields: [walletId], references: [id], onDelete: Cascade)

  @@index([walletId])
  @@map("transactions")
}

model WalletBalance {
  id        String   @id @default(uuid())
  walletId  String
  asset     String // 'ETH' or ERC-20 contract address
  confirmed String // confirmed balance in base units, as a bigint string
  asOfBlock Int?
  updatedAt DateTime @updatedAt

  wallet Wallet @relation(fields: [walletId], references: [id], onDelete: Cascade)

  @@unique([walletId, asset])
  @@map("wallet_balances")
}

// Durable governance/audit record (the "audit_log" of §4). Captures sensitive ACTIONS that
// don't already live in `transactions`/`signed_messages` — policy changes, wallet creation,
// admin reset/seed — so the unified Activity view is a true, queryable audit trail. Standalone
// (no relations): an audit row outlives the wallet/user it references, so we keep ids as plain
// columns and never cascade-delete history.
model AuditLog {
  id        String   @id @default(uuid())
  userId    String
  walletId  String?
  type      String // policy.changed | wallet.created | admin.seed | admin.reset
  detail    Json?
  createdAt DateTime @default(now())

  @@index([userId, createdAt])
  @@map("audit_log")
}

// The single deployed demo ERC-20 (approve/transferFrom demo). One row (id pinned to "singleton")
// — redeploying replaces it. `owner` = the deployer wallet address, i.e. the spender the user
// approves so the admin can transferFrom.
model DemoToken {
  id        String   @id @default("singleton")
  address   String
  owner     String
  createdAt DateTime @default(now())

  @@map("demo_token")
}
